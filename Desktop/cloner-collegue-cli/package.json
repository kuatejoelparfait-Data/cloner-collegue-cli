{
  "name": "cloner-collegue",
  "version": "2.0.0",
  "description": "Clone n'importe quel collegue en double numerique IA. Fonctionne avec Claude, ChatGPT, Mistral et Ollama.",
  "type": "module",
  "bin": {
    "cloner": "./bin/cloner.js"
  },
  "scripts": {
    "start": "node bin/cloner.js",
    "clone": "node bin/cloner.js clone",
    "list": "node bin/cloner.js list",
    "chat": "node bin/cloner.js chat",
    "dev": "node --watch bin/cloner.js"
  },
  "keywords": [
    "ai",
    "clone",
    "colleague",
    "llm",
    "claude",
    "openai",
    "cli"
  ],
  "author": "Kuate Joel Parfait <digital.house.company>",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "inquirer": "^12.3.2",
    "keytar": "^7.9.0",
    "mammoth": "^1.8.0",
    "openai": "^4.82.0",
    "ora": "^8.2.0",
    "pdf-parse": "^1.1.1"
  }
}
